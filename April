<script>
let cur = 0;
let postData = [];
// Safely target the slide nav by class instead of ID in case of ID mismatch
const slideNav = document.querySelector('.slide-nav');

function init() {
  const posts = document.querySelectorAll('.post');
  posts.forEach((p, i) => {
    postData.push({
      el: p,
      type: p.getAttribute('data-type') || 'STATIC',
      meta: p.getAttribute('data-meta') || ''
    });
    if(i === 0) p.classList.add('active');
    else p.classList.remove('active');
  });
  if(postData.length > 0) go(0);
}

function buildSlideNav(idx) {
  if(!postData[idx] || !slideNav) return;
  const d = postData[idx];
  const slides = d.el.querySelectorAll('.slide');
  slideNav.innerHTML = '';
  
  if(slides.length > 1) {
    slideNav.classList.add('visible');
    slides.forEach((s, i) => {
      const btn = document.createElement('button');
      btn.className = 'stab' + (i === 0 ? ' active' : '');
      btn.textContent = (i + 1).toString().padStart(2, '0');
      btn.onclick = () => goSlide(idx, i);
      slideNav.appendChild(btn);
    });
    const label = document.createElement('div');
    label.className = 'slide-label';
    label.textContent = 'SWIPE';
    slideNav.appendChild(label);
  } else {
    slideNav.classList.remove('visible');
  }
}

function goSlide(postIdx, slideIdx) {
  if(!postData[postIdx]) return;
  const slides = postData[postIdx].el.querySelectorAll('.slide');
  if(!slides[slideIdx]) return;
  
  slides.forEach(s => s.classList.remove('s-active'));
  slides[slideIdx].classList.add('s-active');
  
  if(slideNav) {
      const tabs = slideNav.querySelectorAll('.stab');
      tabs.forEach((t, i) => t.classList.toggle('active', i === slideIdx));
  }
}

// ── POST NAV (FIXED & BULLETPROOF) ──
function go(dir) {
  if (!postData || postData.length === 0) return;

  if (postData[cur] && postData[cur].el) {
    postData[cur].el.classList.remove('active');
  }

  const direction = parseInt(dir) || 0;
  let nextIndex = cur + direction;
  
  if (nextIndex < 0) nextIndex = 0;
  if (nextIndex >= postData.length) nextIndex = postData.length - 1;
  
  cur = nextIndex;
  const d = postData[cur];

  if (!d || !d.el) return; 

  d.el.classList.add('active');

  const slides = d.el.querySelectorAll('.slide');
  if (slides.length > 0) {
      slides.forEach((s, i) => s.classList.toggle('s-active', i === 0));
  }

  const counterEl = document.getElementById('counter');
  if (counterEl) {
    counterEl.textContent = String(cur + 1).padStart(2, '0') + '/' + String(postData.length).padStart(2, '0');
  }
  
  const metaEl = document.getElementById('meta');
  if (metaEl) {
    metaEl.textContent = d.meta || '';
  }
  
  const typeEl = document.getElementById('post-type');
  if (typeEl) {
    typeEl.textContent = d.type || '';
  }

  const prevBtn = document.getElementById('prevBtn');
  if (prevBtn) prevBtn.disabled = cur === 0;

  const nextBtn = document.getElementById('nextBtn');
  if (nextBtn) nextBtn.disabled = cur === postData.length - 1;

  buildSlideNav(cur);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Initialize when page loads
document.addEventListener('DOMContentLoaded', init);
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const chromeRight = document.querySelector('.chrome-right');
  if (chromeRight) {
      const exportBtn = document.createElement('button');
      exportBtn.className = 'btn';
      exportBtn.style.background = 'var(--red)';
      exportBtn.style.marginLeft = '10px';
      exportBtn.innerText = '↓ EXPORT HD PNG';
      chromeRight.appendChild(exportBtn);

      exportBtn.addEventListener('click', () => {
        let targetNode = document.querySelector('.post.active .slide.s-active') || document.querySelector('.post.active'); 

        if (targetNode) {
          const originalText = exportBtn.innerText;
          exportBtn.innerText = 'EXPORTING...';
          
          const currentScroll = window.scrollY;
          window.scrollTo(0, 0);

          html2canvas(targetNode, { 
            scale: 2, 
            backgroundColor: null,
            width: 1080,
            height: targetNode.offsetHeight,
            useCORS: true,
            scrollX: 0,
            scrollY: 0
          }).then(canvas => {
            window.scrollTo(0, currentScroll);

            const link = document.createElement('a');
            link.download = `EΩV8-Post-${Date.now()}.png`; 
            link.href = canvas.toDataURL('image/png', 1.0); 
            link.click();
            
            exportBtn.innerText = originalText;
          }).catch(err => {
            console.error("Export failed:", err);
            exportBtn.innerText = 'ERROR';
            setTimeout(() => exportBtn.innerText = originalText, 2000);
          });
        }
      });
  }
});
</script>

